generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma ORM 7: connection URLs belong in `prisma.config.ts`, not here (see P1012).
// - Runtime (pooled): `DATABASE_URL` → `src/server/db/client.ts` (`PrismaPg`).
// - Migrate / CLI: `DIRECT_URL` → `prisma.config.ts` `datasource.url`.
datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ENGINEER
}

enum BrandDesignerType {
  BRAND
  DESIGNER
}

enum MediaUsageType {
  PRODUCT_IMAGE
  BRAND_LOGO
  TESTIMONIAL_AVATAR
  LANDING_IMAGE
  GENERAL
}

enum MediaProvider {
  SUPABASE_STORAGE
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// مستخدم: المالك (يتحكم بالكامل) أو المهندس (عرض سجل التدقيق فقط)
model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole     @default(ENGINEER)
  auditLogs     AuditLog[]
  mediaAssets   MediaAsset[]

  @@index([email])
}

/// ألوان يعرّفها المالك من الداشبورد
model Color {
  id        String   @id @default(cuid())
  label     String
  hex       String?
  sortOrder Int      @default(0)
  deletedAt DateTime?
  items     CollectionItem[]
  variants  ProductVariant[]

  @@index([deletedAt, sortOrder])
}

model CollectionItem {
  id               String          @id @default(cuid())
  titleAr          String
  titleEn          String?
  description      String?
  imageUrl         String
  /// سعر بالدينار الليبي أو عملة `currency` — اختياري
  price            Decimal?        @db.Decimal(12, 2)
  currency         String          @default("LYD")
  category         String
  isPublished      Boolean         @default(true)
  /// Legacy compatibility — يُزامن مع المقاسات المتاحة من variants عند الحفظ من لوحة التحكم
  sizes            String[]        @default([])
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  brandDesignerId  String?
  brandDesigner    BrandDesigner?  @relation(fields: [brandDesignerId], references: [id], onDelete: SetNull)
  colors           Color[]
  images           ProductImage[]
  variants         ProductVariant[]

  @@index([isPublished, deletedAt, category])
  @@index([titleAr])
  @@index([brandDesignerId])
}

/// آراء العملاء — إدارة من الداشبورد، عرض عام للمنشور فقط
model Testimonial {
  id           String    @id @default(cuid())
  customerName String
  text         String
  rating       Int       @default(5)
  imageUrl     String?
  isPublished  Boolean   @default(true)
  sortOrder    Int       @default(0)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([deletedAt, isPublished, sortOrder])
}

/// ماركات ومصممون — ارتباط اختياري بالمنتجات
model BrandDesigner {
  id              String             @id @default(cuid())
  nameAr          String
  nameEn          String?
  type            BrandDesignerType
  logoUrl         String?
  descriptionAr   String?
  descriptionEn   String?
  isPublished     Boolean            @default(true)
  sortOrder       Int                @default(0)
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  collectionItems CollectionItem[]

  @@index([deletedAt, sortOrder])
}

/// مقاس/لون لكل منتج مع التوفر والطلب الخاص — المصدر الرئيسي للعرض العام
model ProductVariant {
  id                String         @id @default(cuid())
  collectionItemId  String
  collectionItem    CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  size              String
  colorId           String?
  colorLabel        String?
  color             Color?         @relation(fields: [colorId], references: [id], onDelete: SetNull)
  quantity          Int            @default(1)
  isAvailable       Boolean        @default(true)
  allowSpecialOrder Boolean        @default(false)
  sortOrder         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([collectionItemId, sortOrder])
  @@index([collectionItemId, size])
  @@index([colorId])
}

/// صور متعددة لكل منتج — الحفاظ على `imageUrl` كنسخة احتياطية للواجهات القديمة
model ProductImage {
  id               String         @id @default(cuid())
  collectionItemId String
  collectionItem   CollectionItem @relation(fields: [collectionItemId], references: [id], onDelete: Cascade)
  url              String
  alt              String?
  isPrimary        Boolean        @default(false)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())

  @@index([collectionItemId, sortOrder])
}

/// مكتبة الوسائط — ملفات مرفوعة إلى Supabase Storage
model MediaAsset {
  id               String          @id @default(cuid())
  path             String          @unique
  url              String
  filename         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  width            Int?
  height           Int?
  alt              String?
  folder           String
  usageType        MediaUsageType  @default(GENERAL)
  provider         MediaProvider   @default(SUPABASE_STORAGE)
  bucket           String
  isArchived       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdById      String?
  createdBy        User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isArchived, folder, createdAt])
  @@index([usageType, isArchived])
  @@index([createdAt])
  @@index([createdById])
}

/// سجل تدقيق: للمراقبة والأمان
model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?

  @@index([createdAt])
  @@index([userId])
  @@index([entityType, entityId])
}
