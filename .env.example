# قاعدة البيانات
# Runtime (pooled): Supabase Transaction pooler / Supavisor (:6543) + `?pgbouncer=true` when required.
# Local: single Postgres URL is fine.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/couture_dress?schema=public"

# Prisma CLI (`migrate`, `db pull`, …): direct PostgreSQL (Supabase `db.<ref>.supabase.co:5432`, or session pooler on :5432).
# Do not use the transaction pooler URL here. For local Postgres without a pooler, set to the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/couture_dress?schema=public"

# Auth.js / NextAuth — مفتاح سري (أنشئه بـ openssl rand -base64 32)
# Use ONE of AUTH_SECRET or NEXTAUTH_SECRET with a non-empty value. Do not leave
# AUTH_SECRET defined but empty in Vercel — that blocks fallback to NEXTAUTH_SECRET
# and breaks Google login after token exchange (error=Configuration).
AUTH_SECRET=""
# Vercel/production: https://www.couture-dress.com (must match the public site URL)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth (Cloud Console: نوع "Web" + Redirect: http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# بريد مالك المتجر (واحد أو عدة عناوين مفصولة بفاصلة) — فقط هؤلاء يحصلون صلاحية كاملة
OWNER_EMAIL="owner@example.com"
# أو: OWNER_EMAILS="a@b.com,owner2@x.com"

# بريد مهندس البرمجيات: يقرأ سجل التدقيق فقط (دون تعديل المحتوى)
ENGINEER_EMAILS="engineer@example.com"

# Temporary: set to "1" to log [middleware] admin auth (hasToken, email, role, secureCookie) — no secrets/cookies.
AUTH_MIDDLEWARE_DEBUG=""

# Google Analytics 4 (Measurement ID — العامّة للمتصفح فقط)
NEXT_PUBLIC_GA_ID=""
# Emergency: set to "true" or "1" to disable GA scripts without removing the ID.
NEXT_PUBLIC_GA_DISABLED=""

# Temporary production stabilization (server-only). Disables GA, skips DB on the public home page,
# and bypasses admin middleware. Remove after the site is healthy.
SITE_RECOVERY=""

# Supabase Storage (server-only — NEVER expose SUPABASE_SERVICE_ROLE_KEY to the browser)
# Create a public bucket (e.g. couture-media) in the Supabase dashboard before uploading.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="couture-media"

# روابط التواصل (الموقع العام)
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=""
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=""
NEXT_PUBLIC_SOCIAL_TIKTOK_URL=""
NEXT_PUBLIC_SOCIAL_SNAPCHAT_URL=""
